# Backend
PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/leads
NODE_ENV=development

# Auth (simple login protected via middleware — no auth lib)
AUTH_USER=admin
AUTH_PASSWORD=change-me-please
SESSION_SECRET=replace-with-a-long-random-string

# Resend
RESEND_API_KEY=re_xxx_your_key_here
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=Your Name
RESEND_WEBHOOK_SECRET=whsec_xxx

# Public URL used in unsubscribe links and webhook targets
PUBLIC_BACKEND_URL=https://your-backend.up.railway.app
PUBLIC_FRONTEND_URL=https://your-frontend.up.railway.app

# Scraper
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; LeadScout/1.0)
SCRAPER_MAX_CONCURRENCY=1
PUPPETEER_HEADLESS=true

# Email sending limits
DEFAULT_HOURLY_SEND_LIMIT=50

# Frontend (build-time)
VITE_API_BASE_URL=https://your-backend.up.railway.app
